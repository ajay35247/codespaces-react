{
  "name": "codespaces-react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@heroicons/react": "^2.0.18",
    "@react-google-maps/api": "^2.20.8",
    "@react-three/fiber": "^8.17.10",
    "@reduxjs/toolkit": "^2.11.2",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.1.2",
    "react-router-dom": "^6.17.0",
    "socket.io-client": "^4.7.5",
    "three": "^0.168.0",
    "web-vitals": "^3.1.0"
  },
  "overrides": {
    "@svgr/webpack": "^8.0.1",
    "@adobe/css-tools": "^4.3.1",
    "postcss": "^8.4.31"
  },
  "scripts": {
    "start": "BROWSER=none WDS_SOCKET_PORT=0 vite --port 3000",
    "backend": "cd backend && npm run dev",
    "build": "vite build",
    "preview": "vite preview",
    "docker:up": "docker-compose up --build",
    "test": "vitest",
    "test:e2e": "playwright test",
    "cap:init": "cap init \"Speedy Trucks\" \"com.speedytrucks.app\" --web-dir=dist",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "cap:android:debug": "npm run build && cap sync android && cd android && ./gradlew assembleDebug --no-daemon"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.19",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.4.0",
    "vite": "^6.3.6",
    "vitest": "^3.0.7"
  }
}
