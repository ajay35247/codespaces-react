# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.

NODE_ENV=production
PORT=5000

# ─── Database (MongoDB Atlas) ─────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/speedy-trucks?retryWrites=true&w=majority

# ─── Redis (Upstash - use rediss:// for TLS) ──────────────────────────────────
REDIS_URL=rediss://:<password>@<host>.upstash.io:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret
JWT_REFRESH_SECRET=replace_with_another_64_byte_hex_secret
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ─── HIDDEN ADMIN SYSTEM (CRITICAL - SINGLE ADMIN ONLY) ──────────────────────
# NEVER expose these in frontend or public code
# Only one admin account can exist in the entire system
ADMIN_EMAIL=ajay35247@gmail.com
ADMIN_BOOTSTRAP_PASSWORD=Sharma@76210

# Secret admin API path segment (unguessable, never disclosed publicly)
# Used to obfuscate hidden control plane from discovery attacks
# Example: _ops_console_f91b7c, _platform_control_a1b2c3, etc.
ADMIN_PRIVATE_PATH_SEGMENT=_ops_console_f91b7c

# Optional: IP whitelist for admin access (comma-separated, blocks non-whitelisted IPs with 403)
# Leave empty to disable IP filtering
# Example: 203.0.113.10,198.51.100.20,192.168.1.0/24
ADMIN_IP_WHITELIST=

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app
CLIENT_URL=https://your-app.vercel.app
# Additional origins (comma-separated) for web previews/mobile WebView
# Example: https://preview.vercel.app,capacitor://localhost,ionic://localhost
ALLOWED_ORIGINS=

# ─── Email (SendGrid SMTP or similar) ────────────────────────────────────────
EMAIL_FROM=noreply@speedytrucks.in
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=your_sendgrid_api_key
EMAIL_SECURE=false
# In production, admin MFA email is required by default.
REQUIRE_ADMIN_MFA_EMAIL=true

# ─── Cookie Security ──────────────────────────────────────────────────────────
# Choose: strict | lax | none (none requires secure cookies over HTTPS)
AUTH_COOKIE_SAME_SITE=lax
COOKIE_SECURE=true
AUTH_COOKIE_DOMAIN=

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=200

# ─── Clustering ───────────────────────────────────────────────────────────────
USE_CLUSTER=false
