# ─── Frontend Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local for development, set in Vercel dashboard for production.
# DO NOT commit .env.local to version control.

# Backend API base URL (no trailing slash, include /api)
VITE_API_URL=https://your-backend.onrender.com/api

# Google Maps (used by TrackingMap)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Razorpay public key (safe to expose in frontend)
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# App environment
VITE_APP_ENV=production
