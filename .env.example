# ─── Frontend Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local for development, set in Vercel dashboard for production.
# DO NOT commit .env.local to version control.

# Backend API base URL (no trailing slash, include /api)
VITE_API_URL=https://your-backend.onrender.com/api

# ─── HIDDEN ADMIN PANEL (SECRET - DO NOT DISCLOSE PUBLICLY) ──────────────────
# Hidden admin panel route path (only accessed via direct URL, not discoverable from UI)
# Example: /ops-bridge-93a1, /control-tower-secret-xyz, etc.
VITE_ADMIN_PANEL_PATH=/ops-bridge-93a1

# Hidden admin API segment (must match backend ADMIN_PRIVATE_PATH_SEGMENT)
# Used to route admin requests to hidden control plane
VITE_ADMIN_API_SEGMENT=_ops_console_f91b7c

# Google Maps (used by TrackingMap)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Razorpay public key (safe to expose in frontend)
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# App environment
VITE_APP_ENV=production
